            "items": [
                {
                    "id": 1,
                    "img": "images/svg/logo.svg",
                    "faIcon": "",
                    "faIconColors": {"bg": "", "fill": ""},
                    "locales": {
                        "en": {
                            "text": "<p>I'm an {{Ethical Hacker}}, {{Penetration Tester}}, and {{Application Security}} specialist with [[over 10 years]] of hands-on experience, primarily focused on securing web applications. I'm self-driven, a fast learner, and deeply security-minded—always eager to explore new technologies and sharpen my skills.</p><p>Beyond software development, I've worked extensively with a variety of web frameworks and technologies including {{PHP}}, {{JavaScript}}, {{Python}}, {{Java}}, {{C#}} and both {{SQL}} and {{NoSQL}} databases. My day-to-day often involves performing in-depth code reviews and conducting security and penetration tests on web/mobile applications and infrastructure networks.</p><p>Outside of work, I enjoy participating in Capture The Flag {{(CTF)}} challenges and unwinding with a good {{movie}}.</p>"
                        }
                    }
                }
            ]
        },
